{
  "permissions": {
    "allow": [
      "Bash(./scripts/safe-gradlew.sh:*)",
      "Read(~/.zshrc)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(do)",
      "Bash(then)",
      "Bash(else)",
      "Bash(fi)",
      "Bash(done)",
      "Bash(for:*)",
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(gh:*)",
      "Bash(git worktree:*)",
      "Bash(bash:*)",
      "Bash(chmod:*)"
    ],
    "deny": [
      "Bash(./gradlew:*)",
      "Bash(sudo:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(curl:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "hooks": {
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '\\n✅ サブエージェント完了！\\n\\n🌳 worktreeを作成する場合:\\n   /create-worktree <feature-name>\\n\\n🚀 実装を開始する場合:\\n   /develop\\n'"
          }
        ]
      }
    ]
  }
}
