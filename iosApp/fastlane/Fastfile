default_platform(:ios)

platform :ios do
  # ======================================
  # Match（証明書管理）
  # ======================================

  desc "開発用証明書を取得"
  lane :sync_certificates_development do
    match(type: "development")
  end

  desc "配布用証明書を取得"
  lane :sync_certificates_appstore do
    match(type: "appstore")
  end

  # ======================================
  # ビルドのみ（CI検証用）
  # ======================================

  desc "iOSアプリをビルドのみ（ビルド検証）"
  lane :build_only do
    build_app(
      project: "iosApp.xcodeproj",
      scheme: "iosApp",
      skip_codesigning: true,
      skip_archive: true,
      destination: "generic/platform=iOS Simulator"
    )
  end

  # ======================================
  # TestFlight 配信
  # ======================================

  desc "TestFlightにベータ版を配信"
  lane :beta do |options|
    # CI環境向けに一時キーチェーンを作成
    setup_ci if is_ci?

    # App Store Connect API Key の設定（CI環境）
    if ENV["APP_STORE_CONNECT_API_KEY_ID"]
      app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
        key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
        is_key_content_base64: true
      )
    end

    # 証明書の同期
    sync_certificates_appstore

    # CI環境: 署名設定をManualに切り替え（matchで取得したプロファイルを使用）
    team_id = ENV['APPLE_TEAM_ID']
    if is_ci? && team_id
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "iosApp.xcodeproj",
        team_id: team_id,
        bundle_identifier: "com.collabstream.app",
        profile_name: "match AppStore com.collabstream.app",
        code_sign_identity: "iPhone Distribution"
      )
    end

    # ビルド番号の設定（CI環境: github.run_numberを使用）
    # xcconfig で CURRENT_PROJECT_VERSION を管理しているため、直接ファイルを更新
    # (agvtool/increment_build_number は xcconfig を参照できない)
    if options[:build_number]
      xcconfig_path = File.join(Dir.pwd, "..", "Configuration", "Config.xcconfig")
      xcconfig_content = File.read(xcconfig_path)
      xcconfig_content = xcconfig_content.gsub(/CURRENT_PROJECT_VERSION=.*/, "CURRENT_PROJECT_VERSION=#{options[:build_number]}")
      File.write(xcconfig_path, xcconfig_content)
      UI.message("ビルド番号を #{options[:build_number]} に設定しました")
    end

    # アプリのビルド（Kotlin Frameworkは Xcode Build Phase で自動ビルド）
    build_app(
      project: "iosApp.xcodeproj",
      scheme: "iosApp",
      export_method: "app-store",
      output_directory: "build",
      output_name: "CollabStream.ipa"
    )

    # TestFlight にアップロード
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end
end
