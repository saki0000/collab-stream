# ============================================================
# .dockerignore
# Docker ビルドコンテキストから除外するファイルを定義する
# ビルドに不要なファイルを除外してビルド時間とイメージサイズを削減する
# ============================================================

# ============================================================
# Git 関連
# ============================================================
.git
.github

# ============================================================
# ビルド成果物
# Gradle のビルド出力ディレクトリを除外する
# ただし Docker 内でビルドを実行するため、ソースは除外しない
# ============================================================
build/
*/build/
.gradle/

# ============================================================
# iOS アプリ関連
# server モジュールのビルドには不要
# ============================================================
iosApp/

# ============================================================
# ドキュメント・開発用ファイル
# ランタイムには不要なドキュメントを除外する
# ============================================================
*.md
.claude/
implement-context/
docs/
screenshots/

# ============================================================
# IDE 設定
# ============================================================
.idea/
*.iml
.worktrees/

# ============================================================
# シークレット・環境変数ファイル
# セキュリティ上の理由から .env ファイルをイメージに含めない
# 環境変数は Cloud Run の Secret Manager から注入する
# ============================================================
.env
.env.*
**/.env
**/.env.*
server/.env

# ============================================================
# OS 固有ファイル
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# テスト関連
# testing/ モジュールは settings.gradle.kts で参照されるため除外しない
# （Gradle の依存関係解決に必要）
# ============================================================
